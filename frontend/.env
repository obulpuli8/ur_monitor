# API Configuration
REACT_APP_API_URL=https://ur-monitor-backend.onrender.com

# Optional: Analytics (if you add Google Analytics later)
REACT_APP_GA_TRACKING_ID=your-ga-tracking-id

# Optional: Sentry (if you add error tracking later)
REACT_APP_SENTRY_DSN=your-sentry-dsn

# Optional: Feature flags
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_NOTIFICATIONS=true